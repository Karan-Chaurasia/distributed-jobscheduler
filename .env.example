# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scheduler_db
DB_USER=scheduler_user
DB_PASSWORD=scheduler_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a cryptographically secure 256-bit secret in production
JWT_SECRET=change-me-in-production-must-be-at-least-256-bits-long
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Embedded worker ─────────────────────────────────────────────────────────
# The application runs an in-process worker that claims and executes jobs.
# Set WORKER_ENABLED=false to run an API-only (control-plane) node.
WORKER_ENABLED=true
WORKER_CONCURRENCY=8
WORKER_POLL_DELAY_MS=2000
